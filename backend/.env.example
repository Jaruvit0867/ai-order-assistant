# Azure AI Foundry agent configuration (same var names as gorilla)
AZURE_EXISTING_AIPROJECT_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com/api/projects/<your-project-name>
AZURE_EXISTING_AGENT_ID=<your-agent-name>:<version>

# Azure Logic App URL for order notifications
LOGIC_APP_ORDER_URL=https://<your-logic-app>.azurewebsites.net:443/api/<your-trigger>/invoke

# Frontend origin (for CORS)
FRONTEND_ORIGIN=http://localhost:5173
